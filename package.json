{
  "name": "daily-summary-blog",
  "private": true,
  "packageManager": "bun@1.3.0",
  "scripts": {
    "build:data": "bun ./scripts/build-summary-feed.mjs",
    "build:css": "bunx tailwindcss -i ./src/styles.css -o ./assets/site.css --minify",
    "build": "bun run build:data && bun run build:css",
    "preview": "bunx serve . -l 4173"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "tailwindcss": "^3.4.19"
  }
}
